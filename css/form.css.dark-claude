/* ============================================================
   DARK MODE — form.css
   Design tokens matched to example-dark-mode.html
   ============================================================ */

:root {
  --bg-page:        #1a1a1a;
  --bg-primary:     #212121;
  --bg-secondary:   #2a2a2a;
  --bg-tertiary:    #333333;
  --text-primary:   #ececec;
  --text-secondary: #a0a0a0;
  --text-tertiary:  #666666;
  --border:         rgba(255, 255, 255, 0.10);
  --border-md:      rgba(255, 255, 255, 0.18);
  --radius-md:      8px;
  --radius-lg:      12px;
  --accent-blue:    #378ADD;
  --accent-green:   #1D9E75;
  --accent-amber:   #EF9F27;
  --accent-red:     #E24B4A;
}

/* --- 1. Global Reset & Body --- */
*, *::before, *::after { box-sizing: border-box; }

html, body {
  height: 100%;
  margin: 0;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  font-size: 14px;
  background-color: var(--bg-page);
  color: var(--text-primary);
  line-height: 1.6;
  overflow: hidden; /* Locks the main window; scrolling happens inside iframes */
}

/* --- 2. Dashboard Layout (The Main Split) --- */
.dashboard-container {
  display: flex;
  flex-direction: row;
  width: 100vw;
  height: 100vh;
  gap: 15px;
  padding: 15px;
  box-sizing: border-box;
}

.pane-wrapper {
  display: flex;
  flex-direction: column;
  flex: 1;
  height: 100%;
  overflow: hidden;
  background-color: var(--bg-primary);
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
}

.label-bar {
  flex-shrink: 0;
  background: var(--bg-secondary);
  padding: 12px 15px;
  border-bottom: 0.5px solid var(--border);
  display: flex;
  align-items: center;
}

.label-bar span {
  font-size: 11px;
  font-weight: 500;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.pane {
  flex-grow: 1;
  width: 100%;
  border: none;
  background: var(--bg-primary);
}

/* --- 3. Form Controls Styling (Inside the iframes) --- */
.controls {
  padding: 20px;
  box-sizing: border-box;
  background-color: var(--bg-primary);
  color: var(--text-primary);
}

.controls label {
  display: block;
  width: 100%;
  margin-bottom: 5px;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-secondary);
}

.controls input[type="text"],
.controls select,
.controls textarea {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 8px 10px;
  border: 0.5px solid var(--border-md);
  border-radius: var(--radius-md);
  margin-bottom: 20px;
  background-color: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
  font-family: 'Consolas', 'Monaco', monospace;
  font-size: 14px;
  outline: none;
  transition: border-color 0.15s;
  -webkit-appearance: none;
}

.controls input[type="text"]:focus,
.controls select:focus,
.controls textarea:focus {
  border-color: rgba(255, 255, 255, 0.35);
}

.controls select {
  cursor: pointer;
}

/* Readonly textarea (e.g. MAC output display) */
.controls textarea[readonly] {
  background-color: var(--bg-tertiary) !important;
  color: var(--text-secondary) !important;
  cursor: default;
}

.controls button {
  display: inline-flex;
  align-items: center;
  padding: 8px 18px;
  margin-right: 8px;
  margin-bottom: 10px;
  border: none;
  border-radius: var(--radius-md);
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  transition: opacity 0.2s;
  /* Primary style — white bg, dark text (matches .btn-primary) */
  background: var(--text-primary);
  color: var(--bg-primary);
}

.controls button:hover {
  opacity: 0.85;
}

.controls button:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

/* Divider */
.controls hr {
  border: none;
  border-top: 0.5px solid var(--border);
  margin: 16px 0;
}

/* --- 4. Credit Card Visual Styling --- */
.credit-card-container {
  position: relative;
  width: 400px;
  height: 250px;
  margin: 10px auto 30px auto;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 15px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
  border: 0.5px solid var(--border-md);
  overflow: hidden;
}

/* The Gold Chip */
.credit-card-container::before {
  content: '';
  position: absolute;
  top: 35%; left: 10%; width: 50px; height: 35px;
  background: linear-gradient(135deg, #ffd700 0%, #b8860b 100%);
  border-radius: 6px;
  z-index: 1;
  opacity: 0.8;
}

.credit-card-container input {
  position: absolute;
  background-color: transparent !important;
  color: #fff !important;
  border: none !important;
  padding: 5px !important;
  margin-bottom: 0 !important;
  z-index: 2;
  font-family: 'Courier New', Courier, monospace;
  caret-color: white;
  -webkit-text-fill-color: #ffffff !important;
}

/* Card Field Positioning */
.card-number-input { top: 60%; left: 8%; width: 85%; font-size: 22px; letter-spacing: 2px; }
.name-input        { top: 82%; left: 8%; width: 50%; font-size: 13px; text-transform: uppercase; }
.expiry-input      { top: 82%; left: 60%; width: 15%; font-size: 13px; text-align: center; }
.cvv-input         { top: 35%; left: 75%; width: 17%; font-size: 13px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.2) !important; }

/* --- 5. Table Styling (For Channel Lists) --- */
#channel-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  color: var(--text-primary);
}

#channel-table th {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  padding: 12px;
  text-align: left;
  border-bottom: 0.5px solid var(--border-md);
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

#channel-table td {
  padding: 12px;
  border-bottom: 0.5px solid var(--border);
  color: var(--text-primary);
}

.method-tag {
  background: var(--accent-blue);
  color: white;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 10px;
  font-weight: bold;
  margin-right: 5px;
}
